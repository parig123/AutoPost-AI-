# ============================================================
# AutoPost AI — Environment Variables Template
# Copy this file to .env and fill in real values for local dev.
# Set these same variables in Vercel's Project Settings for prod.
# ============================================================

# Flask
SECRET_KEY=your_random_secret_key_here_minimum_32_chars

# Database — Use Supabase URI in production, SQLite for local dev
# Production (Supabase): postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=sqlite:///linkedin_ai.db

# Groq AI API Key
GROQ_API_KEY=your_groq_api_key_here

# LinkedIn OAuth Credentials
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Local:      http://localhost:5000/api/auth/callback
# Production: https://your-app.vercel.app/api/auth/callback
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/auth/callback

# Cron Security — Random string shared between Supabase Edge Function and Flask
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
CRON_SECRET=your_random_cron_secret_here
